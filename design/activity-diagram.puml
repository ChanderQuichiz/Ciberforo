@startuml title Diagrama de Actividades - Ciberforo

|publico|
start
:Ingresa a la aplicación;
:Visualiza los temas disponibles;

if (¿Buscar tema de interés?) then (Sí)
  :Realiza búsqueda de temas;
endif

:Selecciona un tema;
:Visualiza el contenido del tema;
:Visualiza los comentarios;

if (¿Desea iniciar sesión?) then (Sí)

  |seguridad|
  if (¿Usuario registrado?) then (Sí)
    :Ingresa credenciales;
    if (¿Credenciales válidas?) then (Sí)
      :Inicia sesión;

      |usuario|
      
      if (¿Publicar tema o comentario?) then (Sí)
        :Publica contenido;
      endif

      if (¿Reportar contenido?) then (Sí)
        :Reporta contenido inapropiado;

        |moderador|
        :Revisa el reporte;

        if (¿Reporte válido?) then (Sí)
          :Elimina el contenido;
          if (¿Sancionar usuario?) then (Sí)
            :Sanciona al usuario infractor;
          endif
        endif

        |usuario|
      endif

      if (¿Editar perfil?) then (Sí)
        :Edita su perfil;
      endif

      |seguridad|
      :Cerrar sesión;

    else (No)
      :Muestra error de credenciales;
    endif

  else (No)
    :Registra una nueva cuenta;
  endif

endif

stop
@enduml